{
	"name": "Rest",
	"properties": {
		"description": "Hits the API and copies the data",
		"annotations": [],
		"type": "RestService",
		"typeProperties": {
			"url": "https://linkedin-job-search-api.p.rapidapi.com",
			"enableServerCertificateValidation": true,
			"authenticationType": "Anonymous",
			"authHeaders": {
				"x-rapidapi-key": {
					"type": "AzureKeyVaultSecret",
					"store": {
						"referenceName": "LS_KV_job_trend_analytics",
						"type": "LinkedServiceReference"
					},
					"secretName": "x-rapidapi-key"
				}
			}
		}
	}
}